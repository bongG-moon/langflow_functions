{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HTML Report Component Catalog",
  "type": "object",
  "required": ["catalog_version", "components"],
  "properties": {
    "catalog_version": {"type": "string"},
    "components": {
      "type": "array",
      "items": {"$ref": "#/$defs/component"},
      "minItems": 1
    },
    "recommended_components": {
      "type": "array",
      "items": {"$ref": "#/$defs/recommendation"}
    },
    "template_defaults": {"type": "object"},
    "style_presets": {
      "oneOf": [
        {"type": "object"},
        {"type": "array"}
      ]
    },
    "report_presets": {
      "oneOf": [
        {"type": "object"},
        {"type": "array"}
      ]
    },
    "catalog_notes": {"type": "array", "items": {"type": "string"}},
    "selection_context": {"type": "object"}
  },
  "$defs": {
    "component": {
      "type": "object",
      "required": ["component_id", "family", "display_name", "description", "data_contract"],
      "properties": {
        "component_id": {"type": "string"},
        "family": {"type": "string"},
        "display_name": {"type": "string"},
        "description": {"type": "string"},
        "layout_role": {"type": "string"},
        "best_for": {"type": "array", "items": {"type": "string"}},
        "avoid_when": {"type": "array", "items": {"type": "string"}},
        "intent_hints": {"type": "array", "items": {"type": "string"}},
        "data_contract": {
          "type": "object",
          "properties": {
            "requires_numeric": {"type": "boolean"},
            "requires_dimension": {"type": "boolean"},
            "requires_time": {"type": "boolean"},
            "supports_preview_rows": {"type": "boolean"},
            "min_rows": {"type": "integer", "minimum": 0},
            "preferred_columns": {"type": "array", "items": {"type": "string"}}
          },
          "additionalProperties": true
        },
        "compatible_with": {"type": "array", "items": {"type": "string"}},
        "default_priority": {"type": "integer"},
        "template_guidance": {"type": "string"},
        "style_defaults": {"type": "object"},
        "default_spec": {"type": "object"},
        "example_spec": {"type": "object"}
      },
      "additionalProperties": true
    },
    "recommendation": {
      "type": "object",
      "required": ["component_id", "reason"],
      "properties": {
        "component_id": {"type": "string"},
        "reason": {"type": "string"},
        "confidence": {"type": "string", "enum": ["low", "medium", "high"]},
        "suggested_bindings": {"type": "object"}
      },
      "additionalProperties": true
    }
  }
}
