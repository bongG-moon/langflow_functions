{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HTML Report Plan",
  "type": "object",
  "required": ["plan_version", "title", "blocks"],
  "properties": {
    "plan_version": {"type": "string"},
    "title": {"type": "string"},
    "subtitle": {"type": "string"},
    "layout": {"type": "string", "enum": ["report", "dashboard", "query_review", "diagnosis"]},
    "blocks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {"$ref": "#/$defs/block"}
    },
    "warnings": {"type": "array", "items": {"type": "string"}}
  },
  "$defs": {
    "block": {
      "type": "object",
      "required": ["block_id", "title"],
      "properties": {
        "block_id": {
          "type": "string",
          "enum": [
            "report_header",
            "scope_summary",
            "kpi_card_grid",
            "metric_delta_card_grid",
            "comparison_bar_chart",
            "stacked_comparison_bar",
            "trend_line_chart",
            "period_comparison_table",
            "ranking_table",
            "rank_change_table",
            "detail_data_table",
            "pivot_matrix_table",
            "distribution_histogram",
            "outlier_exception_table",
            "warning_box",
            "insight_bullets",
            "recommendation_list",
            "empty_state",
            "method_note"
          ]
        },
        "title": {"type": "string"},
        "caption": {"type": "string"},
        "columns": {"type": "array", "items": {"type": "string"}},
        "x": {"type": "string"},
        "y": {"type": "string"},
        "series": {"type": "string"},
        "metrics": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "column"],
            "properties": {
              "label": {"type": "string"},
              "column": {"type": "string"},
              "aggregation": {"type": "string", "enum": ["sum", "avg", "min", "max", "count", "nunique"]},
              "format": {"type": "string"}
            },
            "additionalProperties": false
          }
        },
        "sort": {
          "type": "object",
          "properties": {
            "by": {"type": "string"},
            "direction": {"type": "string", "enum": ["asc", "desc"]}
          },
          "additionalProperties": false
        },
        "limit": {"type": "integer", "minimum": 1, "maximum": 100},
        "notes": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
