      },
      "insight_bullets": {
        "width": "half",
        "emphasis": "high",
        "description": "가장 중요한 발견을 짧은 문장으로 요약합니다."
      },
      "donut_chart": {
        "width": "half",
        "emphasis": "medium",
        "chart_policy": {
